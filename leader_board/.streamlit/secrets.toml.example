# .streamlit/secrets.toml — 로컬 테스트용 (git에 포함하지 마세요)
# Streamlit Community Cloud 배포 시엔 대시보드에서 직접 입력하세요.

# Google Drive API 키 발급:
#   1. console.cloud.google.com → 새 프로젝트 생성
#   2. API 및 서비스 → Drive API 활성화
#   3. 사용자 인증 정보 → API 키 만들기
GOOGLE_API_KEY = "AIzaSy..."

# WOE/IV 결과가 저장되는 Drive 폴더 ID
#   Drive에서 결과 폴더 열기 → URL의 마지막 부분 복사
#   예: https://drive.google.com/drive/folders/<FOLDER_ID>  (?hl=ko 는 제외)
RESULTS_FOLDER_ID = "1abc..."
